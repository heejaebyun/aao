# === AAO MVP — API Keys ===
# Copy this to .env.local and fill in your keys

# Jina AI Reader — URL 크롤링
JINA_API_KEY=your_jina_api_key_here

# OpenAI — 진단 엔진 + ChatGPT 답변 확인
OPENAI_API_KEY=your_openai_api_key_here
# Optional overrides
# OPENAI_MODEL=gpt-5-mini
# DIAGNOSE_OPENAI_MODEL=gpt-5-mini
# AI_CHECK_OPENAI_MODEL=gpt-5-mini

# Google Gemini — Gemini 답변 확인
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Optional overrides
# GEMINI_STRICT_RECALL_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_LIVE_SEARCH_MODEL=gemini-3.1-flash-lite-preview

# Perplexity — Perplexity 답변 확인
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Optional — AI Check cost guard / Phase 2 Lite
AI_CHECK_INTENTS=awareness,comparison,purchase
AI_CHECK_MAX_TASKS=7
AI_CHECK_CACHE_TTL_MS=1800000
AI_CHECK_CACHE_MAX_ENTRIES=200
AI_CHECK_ENABLE_CHATGPT_STRICT_RECALL=true
AI_CHECK_DEBUG_PAYLOADS=false
AI_CHECK_OPENAI_MODEL=gpt-5-mini
AI_CHECK_ENABLE_AI_RECOGNITION_FALLBACK=true
AI_CHECK_RECOGNITION_MODEL=gpt-5-mini

# Optional — Wikipedia benchmark pilot
# WIKI_BENCHMARK_OPENAI_MODEL=gpt-5-mini
# WIKI_BENCHMARK_GEMINI_MODEL=gemini-3.1-flash-lite-preview
# WIKI_BENCHMARK_PERPLEXITY_MODEL=sonar
# WIKI_BENCHMARK_MAX_INPUT_CHARS=24000

# Optional — distributed rate limiting for production (recommended)
UPSTASH_REDIS_REST_URL=your_upstash_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# Optional — Phase 1.5 commercial channels
NEXT_PUBLIC_AAO_PAYMENT_LINK=https://payments.example.com/aao-profile
NEXT_PUBLIC_AAO_KICKOFF_LINK=https://cal.example.com/aao/kickoff
NEXT_PUBLIC_AAO_STATUS_LINK=https://forms.example.com/aao-status
NEXT_PUBLIC_AAO_CHAT_LINK=https://open.kakao.com/o/example
